    {
      "name": "6. Error Testing",
      "item": [
        {
          "name": "Test - Không có token (401)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/owner/me",
              "host": ["{{base_url}}"],
              "path": ["api", "owner", "me"]
            },
            "description": "Khi không gửi token → 401 Unauthorized"
          },
          "response": []
        },
        {
          "name": "Test - Token user (403)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{user_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/owner/me",
              "host": ["{{base_url}}"],
              "path": ["api", "owner", "me"]
            },
            "description": "Khi dùng user token thay vì owner token → 403 Forbidden"
          },
          "response": []
        },
        {
          "name": "Test - Venue không tồn tại (404)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{owner_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/owner/venues/99999",
              "host": ["{{base_url}}"],
              "path": ["api", "owner", "venues", "99999"]
            },
            "description": "Khi venue ID không tồn tại → 404 Not Found"
          },
          "response": []
        },
        {
          "name": "Test - Email đã tồn tại (422)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Owner 2\",\n  \"email\": \"owner@test.com\",\n  \"password\": \"password123\",\n  \"confirm_password\": \"password123\",\n  \"phone\": \"0901234567\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/owner/register",
              "host": ["{{base_url}}"],
              "path": ["api", "owner", "register"]
            },
            "description": "Khi đăng ký với email đã tồn tại → 422 Validation error"
          },
          "response": []
        }
      ]
    }
  ],
